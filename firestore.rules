rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidReport(request.resource.data);
      allow get: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'timestamp', 'path', 'userData', 'report', 'photos', 'userId']) &&
             data.id is string &&
             data.userId is string &&
             data.path is string &&
             data.userData is map &&
             data.report is map &&
             data.photos is map;
    }
  }
}
