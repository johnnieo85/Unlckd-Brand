{
  "entities": {
    "Report": {
      "title": "Saved Transformation Report",
      "description": "User transformation report data including photos and analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "path": { "type": "string" },
        "userData": { "type": "object" },
        "report": { "type": "object" },
        "photos": { "type": "object" },
        "progressPhotos": { "type": "object" }
      },
      "required": ["id", "timestamp", "path", "userData", "report", "photos"]
    },
    "User": {
      "title": "User Profile",
      "description": "User account information and access status",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "hasAccess": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" }
      },
      "required": ["userId", "email", "hasAccess"]
    },
    "DailyLog": {
      "title": "Daily Activity Log",
      "description": "Daily tracking for steps, water, meals, and habits",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "steps": { "type": "number" },
        "stepGoal": { "type": "number" },
        "water": { "type": "number" },
        "waterGoal": { "type": "number" },
        "meals": { "type": "array", "items": { "type": "object" } },
        "habits": { "type": "object" },
        "completedWorkouts": { "type": "number" }
      },
      "required": ["id", "date"]
    },
    "Measurement": {
      "title": "Body Measurement",
      "description": "Tracking body stats over time",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "weight": { "type": "number" },
        "bodyFat": { "type": "number" },
        "waist": { "type": "number" },
        "chest": { "type": "number" },
        "arms": { "type": "number" }
      },
      "required": ["id", "timestamp"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of transformation reports"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and access grants"
    },
    "/users/{userId}/dailyLogs/{date}": {
      "schema": "DailyLog",
      "description": "Daily activity tracking"
    },
    "/users/{userId}/measurements/{measurementId}": {
      "schema": "Measurement",
      "description": "Historical body measurements"
    }
  }
}
